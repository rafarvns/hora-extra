PORT=5000
UDP_PORT=5001
DB_HOST_PORT=3307

# URL de conexão com o banco de dados (Prisma)
# Exemplo local: mysql://root:root@localhost:3306/hora_extra_db
DATABASE_URL="mysql://usuario:senha@host:porta/nome_do_banco"

# Configuração de Autenticação (JWT)
JWT_SECRET="seu_segredo_super_secreto_aqui_de_pelo_menos_32_caracteres"
JWT_EXPIRES_IN=1h

# Ambiente (development, production)
NODE_ENV=development

# Database Mode (true for SQLite, false for MySQL)
# Se true, o servidor usará um banco local SQLite (prisma/dev.db) sem compromisso.
USE_SQLITE=false

# Teste em Ambiente de Desenvolvimento (SocketIO/UDP Bypass)
# Use estes valores para testar o socket no Unity sem precisar de login real.
# ATENÇÃO: Isso só funciona se NODE_ENV estiver definido como 'development' no servidor.
DEV_TEST_TOKEN="horaextra_dev_test_token_2026"
DEV_TEST_USER_ID="dev-test-player-id-001"
